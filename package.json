{
  "name": "@basaltbytes/odoo-agentic-dev",
  "version": "0.1.0-beta.2",
  "description": "Agent-friendly local Odoo development runtime: worktree-isolated databases, ports, and Docker Compose stacks",
  "keywords": [
    "agentic",
    "cli",
    "development-environment",
    "devtools",
    "docker",
    "docker-compose",
    "effect",
    "git-worktree",
    "odoo"
  ],
  "homepage": "https://github.com/basaltbytes/odoo-agentic-dev#readme",
  "bugs": {
    "url": "https://github.com/basaltbytes/odoo-agentic-dev/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/basaltbytes/odoo-agentic-dev.git"
  },
  "bin": {
    "oad": "./dist/cli.js",
    "odoo-agentic-dev": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm build && pnpm test"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.78",
    "effect": "4.0.0-beta.78",
    "jiti": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.0.8",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.15"
  }
}
